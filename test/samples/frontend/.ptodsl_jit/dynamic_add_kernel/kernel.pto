          pto.tadd ins(%0, %1 : !pto.tile_buf<loc=vec, dtype=f16, rows=64, cols=128, v_row=64, v_col=128, blayout=row_major, slayout=none_box, fractal=512, pad=0>, !pto.tile_buf<loc=vec, dtype=f16, rows=64, cols=128, v_row=64, v_col=128, blayout=row_major, slayout=none_box, fractal=512, pad=0>) outs(%2 : !pto.tile_buf<loc=vec, dtype=f16, rows=64, cols=128, v_row=64, v_col=128, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
          pto.set_flag[<PIPE_V>, <PIPE_MTE2>, <EVENT_ID2>]
          pto.set_flag[<PIPE_V>, <PIPE_MTE3>, <EVENT_ID0>]
