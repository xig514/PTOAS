          pto.tstore ins(%2 : !pto.tile_buf<loc=vec, dtype=f16, rows=64, cols=128, v_row=64, v_col=128, blayout=row_major, slayout=none_box, fractal=512, pad=0>) outs(%17 : !pto.partition_tensor_view<64x128xf16>)
          pto.set_flag[<PIPE_MTE3>, <PIPE_V>, <EVENT_ID1>]
