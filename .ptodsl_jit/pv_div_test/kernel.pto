      %2 = arith.muli %arg8, %c1 : index
      %3 = pto.make_tensor_view %arg6, shape = [%arg7, %arg8], strides = [%2, %c1] : !pto.tensor_view<?x?xf32>
      %4 = pto.partition_view %3, offsets = [%c0, %c0_0], sizes = [%c64, %c64_1] : !pto.tensor_view<?x?xf32> -> !pto.partition_tensor_view<64x64xf32>
      pto.tload ins(%4 : !pto.partition_tensor_view<64x64xf32>) outs(%0 : !pto.tile_buf<loc=vec, dtype=f32, rows=64, cols=64, v_row=64, v_col=64, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
      pto.set_flag[<PIPE_MTE2>, <PIPE_V>, <EVENT_ID0>]
